{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aegis Protocol",
  "version": "0.1.0",
  "identifier": "com.saket.aegis-protocol",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Aegis Protocol",
        "width": 1100,
        "height": 700,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src 'self' http://127.0.0.1:* http://localhost:* http://10.130.151.166:* https://*.supabase.co; img-src 'self' data: blob: http://127.0.0.1:* http://localhost:* http://10.130.151.166:*; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
